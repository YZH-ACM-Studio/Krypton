{
    "files.autoGuessEncoding": false,
    "files.encoding": "utf8",
    "files.eol": "\n",
    "editor.detectIndentation": true,
    "typescript.tsdk": "node_modules/typescript/lib",
    "typescript.tsserver.maxTsServerMemory": 16384,
    "typescript.tsserver.nodePath": "node",
    "[json]": {
        "files.insertFinalNewline": true,
        "files.trimFinalNewlines": false
    },
    "search.exclude": {
        "**/.yarn": true,
        "**/.pnp.*": true
    },
    "files.associations": {
        "*.html": "nunjucks"
    },
    "cmake.sourceDirectory": "${workspaceFolder}/ecosystems/KryptonVigilSystem/Client",
    "cmake.configurePreset": "macos-homebrew-qt",
    "cmake.buildPreset": "macos-homebrew-qt",
    "C_Cpp.default.compileCommands": "${workspaceFolder}/ecosystems/KryptonVigilSystem/Client/build/macos-homebrew-qt/compile_commands.json"
}
